# MediSync Environment Variables
# Copy this to .env and fill in your values

# Application Settings
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ============================================
# COHERE AI - LLM GENERATION ONLY
# ============================================
# IMPORTANT: Get your free API key from https://dashboard.cohere.com/
COHERE_API_KEY=
COHERE_MODEL=command-r

# ============================================
# LOCAL GPU EMBEDDINGS CONFIGURATION
# ============================================
# Embeddings run locally on your CUDA GPU!
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# GPU Settings
EMBEDDING_DEVICE=cuda  # Use 'cuda' for GPU, 'cpu' as fallback

# Data Directories
DATA_DIR=data
UPLOAD_DIR=data/uploads
EMBEDDINGS_DIR=data/embeddings
CHROMA_PERSIST_DIRECTORY=data/embeddings/chromadb

# Embedding Settings
EMBEDDING_BATCH_SIZE=32
CHUNK_SIZE=512
CHUNK_OVERLAP=100
