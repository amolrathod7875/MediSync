# MediSync .gitignore

# Environment files (NEVER commit these!)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Data
data/uploads/*
data/embeddings/chromadb/*
!data/uploads/.gitkeep
!data/embeddings/.gitkeep

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
